{% macro verify() -%}
command codex --version
{%- endmacro %}

{% macro start(model_argument, sandbox_flag) -%}
command codex exec -C "$REPO" \
  --model {{ model_argument }} \
  -c model_reasoning_effort="$EFFORT" \
  --json \
  {{ sandbox_flag }} \
  -o "$OUT" \
  - < "$PROMPT_FILE" > "$EVENTS" 2>/dev/null
{%- endmacro %}

{% macro resume(model_argument, sandbox_flag) -%}
(cd "$REPO" \
  && SESSION_ID=$(rg -m1 -o '"thread_id":"([0-9a-fA-F-]+)"' -r '$1' "$EVENTS") \
  && command codex exec resume "$SESSION_ID" \
  --model {{ model_argument }} \
  -c model_reasoning_effort="$EFFORT" \
  {{ sandbox_flag }} \
  -o "$OUT" \
  - < "$PROMPT_FILE" 2>/dev/null)
{%- endmacro %}

{% macro inspect_process() -%}
pgrep -fl -- "$OUT" || true
{%- endmacro %}
